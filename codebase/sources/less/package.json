{
  "name": "gantt-skins",
  "version": "1.0.0",
  "description": "LESS sources and a build tool for Gantt chart skins",
  "scripts": {
    "build": "node scripts.js --file=dhtmlxgantt",
    "watch": "npm-watch build"
  },
  "watch": {
    "build": {
      "patterns": [
        "./"
      ],
      "extensions": "less"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AminZibayi/Gantt"
  },
  "author": "AminZibayi",
  "license": "GPL-2.0",
  "homepage": "https://github.com/AminZibayi/Gantt",
  "dependencies": {
    "less": "^3.0.4",
    "minimist": "^1.2.6",
    "npm-watch": "^0.11.0",
    "postcss": "^8.4.14",
    "postcss-url": "^10.1.3"
  },
  "devDependencies": {}
}
